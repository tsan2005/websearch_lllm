{
  "name": "mcp_websearch",
  "version": "0.1.0",
  "description": "MCP server for web search with full page content extraction",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp_websearch": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node ./dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bundle": "node scripts/bundle.js"
  },
  "keywords": [
    "mcp",
    "web-search",
    "ai",
    "llm"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "openai": "^6.38.0",
    "p-limit": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.1",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
